# Local development defaults. Railway sets PORT automatically in production.
PORT=5000

# Postgres connection string. Railway sets this when you add a Postgres plugin.
# DATABASE_URL=postgresql://user:password@localhost:5432/nemka

# Comma-separated browser origins allowed to call the API (extension + setup page).
# Use * for development; set your Railway URL in production, e.g.:
# CORS_ORIGINS=https://nemka.ip
CORS_ORIGINS=*

# Required to read GET /api/stats/summary. Pass as X-Stats-Key request header.
# Without this set, the stats endpoint returns 404.
STATS_API_KEY=change-me-to-a-long-random-secret
